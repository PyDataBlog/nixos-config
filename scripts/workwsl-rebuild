#!/usr/bin/env bash
set -euo pipefail

# Bootstrap the first on-device switch by giving the current Nix daemon a CA
# bundle that includes the work-network intercept certificate.
if [[ -n "${ZSCALER_PEM_FILE:-}" ]]; then
  pem_file="${ZSCALER_PEM_FILE}"
elif [[ -n "${ZSCALER_PEM:-}" ]]; then
  pem_file="$(mktemp "${TMPDIR:-/tmp}/workwsl-zscaler.XXXXXX.pem")"
  printf '%s\n' "${ZSCALER_PEM}" >"${pem_file}"
else
  printf 'Set ZSCALER_PEM_FILE or ZSCALER_PEM before running %s\n' "$0" >&2
  exit 1
fi

if [[ ! -f "${pem_file}" ]]; then
  printf 'Corporate CA file not found: %s\n' "${pem_file}" >&2
  exit 1
fi

ca_bundle="$(mktemp "${TMPDIR:-/tmp}/workwsl-ca-bundle.XXXXXX.crt")"

cleanup() {
  rm -f "${ca_bundle}"
  if [[ -n "${ZSCALER_PEM:-}" ]]; then
    rm -f "${pem_file}"
  fi
}

trap cleanup EXIT

if [[ -f /etc/ssl/certs/ca-certificates.crt ]]; then
  cat /etc/ssl/certs/ca-certificates.crt "${pem_file}" >"${ca_bundle}"
else
  cat "${pem_file}" >"${ca_bundle}"
fi

exec sudo env \
  ZSCALER_PEM_FILE="${pem_file}" \
  NIX_SSL_CERT_FILE="${ca_bundle}" \
  SSL_CERT_FILE="${ca_bundle}" \
  nixos-rebuild switch \
  --option ssl-cert-file "${ca_bundle}" \
  --flake "${WORKWSL_FLAKE:-.#workwsl}" \
  --accept-flake-config \
  --impure \
  "$@"
